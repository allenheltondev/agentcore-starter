version: 0.1

default:
  global:
    parameters:
      stack_name: ${STACK_NAME}
      region: ${AWS_REGION}
      capabilities: CAPABILITY_IAM
      confirm_changeset: false
      s3_prefix: ${PROJECT_NAME}-frontend
      disable_rollback: false

  deploy:
    parameters:
      stack_name: ${STACK_NAME}
      region: ${AWS_REGION}
      capabilities: CAPABILITY_IAM
      confirm_changeset: false
      s3_prefix: ${PROJECT_NAME}-frontend
      disable_rollback: false

  delete:
    parameters:
      stack_name: ${STACK_NAME}
      region: ${AWS_REGION}
      no_prompts: true
